rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For Paradise Bucket, we check if the user's email is in our allowed list 
      // or if they exist in the admins collection.
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == 'fadhlihadisurya@gmail.com') || 
        (request.auth.token.email_verified == true && exists(/databases/$(database)/documents/admins/$(request.auth.uid)))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'description', 'marketplaceLinks', 'imageUrl', 'isBestSeller', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.trim().size() > 0 && data.name.size() <= 100
        && data.price is number && data.price >= 0
        && data.category in ['Hand Bouquet', 'Box Bouquet', 'Round Bouquet', 'Standing Flower', 'Money Bouquet']
        && data.description is string && data.description.size() <= 1000
        && data.marketplaceLinks is map
        && data.imageUrl is string && data.imageUrl.size() <= 2048
        && data.isBestSeller is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidActivityLog(data) {
      return data.keys().hasAll(['adminEmail', 'actionType', 'targetId', 'targetName', 'timestamp'])
        && data.keys().size() == 5
        && data.adminEmail == request.auth.token.email
        && data.actionType in ['CREATE', 'UPDATE', 'DELETE']
        && data.targetId is string
        && data.targetName is string
        && data.timestamp == request.time;
    }

    // --- Collection Rules ---

    // Products: User can read, Admin can CRUD
    match /products/{productId} {
      allow read: if true; // Public catalog
      allow create: if isAdmin() 
                    && isValidId(productId) 
                    && isValidProduct(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
      
      allow update: if isAdmin()
                    && isValidId(productId)
                    && isValidProduct(incoming())
                    && incoming().updatedAt == request.time
                    && incoming().createdAt == existing().createdAt // Immutable
                    && (
                      // Allow update on all editable fields
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'category', 'description', 'marketplaceLinks', 'imageUrl', 'isBestSeller', 'updatedAt'])
                    );
      
      allow delete: if isAdmin() && isValidId(productId);
    }

    // Activity Logs: Admin can append only, read
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin() 
                    && isValidId(logId) 
                    && isValidActivityLog(incoming());
      // No update or delete allowed for audit integrity
    }

    // Admins collection: Bootstrapping / Managed
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed manually for now
    }
  }
}
