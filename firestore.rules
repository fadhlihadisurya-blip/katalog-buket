rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == 'fadhlihadisurya@gmail.com') || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation ---
    function isValidProduct(data) {
      // Basic validation to prevent junk data, but flexible enough to work
      return data.name is string && data.name.size() > 0
        && data.price is number
        && data.category is string
        && data.description is string
        && data.imageUrl is string && data.imageUrl.size() < 1048576
        && data.updatedAt is timestamp;
    }

    // --- Collection Rules ---

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming()) && incoming().createdAt is timestamp;
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && request.resource.data.adminEmail == request.auth.token.email;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
